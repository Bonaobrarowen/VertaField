{
  "name": "vertafield",
  "version": "1.0.0",
  "description": "VertaField — agricultural transport quality tracking mobile app",
  "private": true,
  "scripts": {
    "start": "npx serve www -l 3000",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "android": "npm run cap:sync && npm run cap:android",
    "ios": "npm run cap:sync && npm run cap:ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "serve": "^14.2.4"
  }
}
